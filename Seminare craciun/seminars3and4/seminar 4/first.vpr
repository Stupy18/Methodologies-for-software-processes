method sum(n: Int) returns (r: Int)
    requires n >= 0
    ensures r == n * (n + 1) / 2
    decreases n
{
    if (n == 0) {
        r := 0
    } else {
        var prev: Int
        prev := sum(n - 1)
        r := n + prev
    }
}

method main() {
    var r: Int
    r := sum(10)
    assert r == 55
}