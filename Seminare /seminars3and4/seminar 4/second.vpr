method M(n: Int) returns (r: Int)
    requires n >= 0
    ensures 100 < n ==> r == n - 10
    ensures n <= 100 ==> r == 91
    // "How far is the current n from the stopping point?"
    decreases (n > 100) ? 0 : (101 - n)
{
    if (n > 100) {
        r := n - 10
    } else {
        r := M(n + 11)
        r := M(r)
    }
}

// n + 11 > 100?
//   if n > 89:  yes -> n+11 is in [101..111], measure becomes 0
//   if n ≤ 89:  no  -> measure becomes 101 - (n+11) = 90 - n