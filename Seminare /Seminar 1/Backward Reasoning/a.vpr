method a(x: Int, y: Int) returns (X:Int, Y: Int)
  requires true
  ensures X == y && Y == x
{
  X := y - x
    // WP0 = (y- y + x = x) = (x = x). assert true


  Y := y - X
  // WP1 = (y - X + X = y) && (y - X = x) => (y = y always true) && (y - X = x)

  X := Y + X
  // WP2 = (Y + X = y) && (Y = x)
}

// WP3 = (X = y) && (Y = x)
